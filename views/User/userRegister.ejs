<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Register</title>
</head>

<body
    style="margin:0; font-family:'Segoe UI', sans-serif; background:#667eea; display:flex; justify-content:center; align-items:center; height:100vh;">

    <div style="background:#fff; padding:23px; width:340px; border-radius:8px; border:1px solid #ddd;">

        <h2 style="text-align:center; margin-bottom:15px; color:#333; font-size:18px;">
            Create Account
        </h2>

        <form action="/user/new" method="POST">

            <label style="font-size:13px; color:#555;">Full Name</label>
            <input type="text" name="fullname"
                style="width:100%; padding:8px; margin:5px 0 10px 0; border:1px solid #ccc; border-radius:4px; font-size:13px;">

            <label style="font-size:13px; color:#555;">Email</label>
            <input type="email" name="email"
                style="width:100%; padding:8px; margin:5px 0 10px 0; border:1px solid #ccc; border-radius:4px; font-size:13px;">

            <label style="font-size:13px; color:#555;">Phone</label>
            <input type="text" name="phone"
                style="width:100%; padding:8px; margin:5px 0 10px 0; border:1px solid #ccc; border-radius:4px; font-size:13px;">

            <label style="font-size:13px; color:#555;">Gender</label><br>

            <input type="radio" name="gender" value="male">
            <label style="margin-right:12px; font-size:13px;">Male</label>

            <input type="radio" name="gender" value="female">
            <label style="font-size:13px;">Female</label>

            <br>

            <label style="font-size:13px; color:#555;">Password</label>
            <input type="password" name="password"
                style="width:100%; padding:8px; margin:5px 0 10px 0; border:1px solid #ccc; border-radius:4px; font-size:13px;">

            <label style="font-size:13px; color:#555;">Confirm Password</label>
            <input type="password" name="confirmPassword"
                style="width:100%; padding:8px; margin:5px 0 12px 0; border:1px solid #ccc; border-radius:4px; font-size:13px;">

            <button type="submit"
                style="width:100%; padding:8px; background:#333; color:white; border:none; border-radius:4px; cursor:pointer; font-size:14px;">
                Register
            </button>

        </form>

        <a href="/user">
            <button
                style="width:100%; padding:8px; margin-top:8px; background:white; border:1px solid #333; border-radius:4px; cursor:pointer; font-size:14px;">
                Back to Login
            </button>
        </a>

    </div>

</body>

</html>